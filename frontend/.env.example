# Otomeshon Frontend Environment Configuration Template
# Copy this file to .env and update the values for your environment

# =============================================================================
# API Configuration
# =============================================================================
# Backend API Base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket URL for real-time features
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# API Timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=10000

# =============================================================================
# Authentication Configuration
# =============================================================================
# Authentication mode: 'simple' or 'keycloak'
NEXT_PUBLIC_AUTH_MODE=simple

# Keycloak Configuration (when using keycloak mode)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=otomeshon
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=otomeshon-client

# Session timeout (minutes)
NEXT_PUBLIC_SESSION_TIMEOUT=480

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable major features
NEXT_PUBLIC_ENABLE_WORKFLOW_EXECUTOR=true
NEXT_PUBLIC_ENABLE_SOP_MANAGER=true
NEXT_PUBLIC_ENABLE_DATA_SANDBOX=true
NEXT_PUBLIC_ENABLE_KNOWLEDGE_GRAPH=true
NEXT_PUBLIC_ENABLE_REAL_TIME_MONITORING=true

# Development features
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# =============================================================================
# Banking Configuration
# =============================================================================
# Default currency for transactions
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Maximum transaction amount for UI validation
NEXT_PUBLIC_MAX_TRANSACTION_AMOUNT=10000000

# Date formats
NEXT_PUBLIC_DATE_FORMAT=MM/dd/yyyy
NEXT_PUBLIC_DATETIME_FORMAT=MM/dd/yyyy HH:mm:ss

# =============================================================================
# UI/UX Settings
# =============================================================================
# Theme mode: 'light', 'dark', or 'auto'
NEXT_PUBLIC_DEFAULT_THEME=light

# Page size defaults
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=50
NEXT_PUBLIC_MAX_PAGE_SIZE=500

# Chart refresh interval (seconds)
NEXT_PUBLIC_CHART_REFRESH_INTERVAL=30

# =============================================================================
# Performance Settings
# =============================================================================
# Enable service worker for caching
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true

# Virtual scrolling threshold
NEXT_PUBLIC_VIRTUAL_SCROLL_THRESHOLD=1000

# Debounce delay for search (milliseconds)
NEXT_PUBLIC_SEARCH_DEBOUNCE=300

# =============================================================================
# Development Settings
# =============================================================================
# Show development tools
NEXT_PUBLIC_SHOW_DEV_TOOLS=false

# API request logging
NEXT_PUBLIC_LOG_API_REQUESTS=false

# Performance monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false

# =============================================================================
# Security Settings
# =============================================================================
# Content Security Policy reporting
NEXT_PUBLIC_CSP_REPORT_URI=/api/csp-report

# Enable strict mode for React
NEXT_PUBLIC_REACT_STRICT_MODE=true