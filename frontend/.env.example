# Otomeshon Frontend Environment Configuration Template
# Copy this file to .env and update the values for your environment

# =============================================================================
# API Configuration
# =============================================================================
# Backend API Base URL
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for real-time features
VITE_WS_URL=ws://localhost:8000

# API Timeout (milliseconds)
VITE_API_TIMEOUT=10000

# =============================================================================
# Authentication Configuration
# =============================================================================
# Authentication mode: 'simple' or 'keycloak'
VITE_AUTH_MODE=simple

# Keycloak Configuration (when using keycloak mode)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=otomeshon
VITE_KEYCLOAK_CLIENT_ID=otomeshon-client

# Session timeout (minutes)
VITE_SESSION_TIMEOUT=480

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable major features
VITE_ENABLE_WORKFLOW_EXECUTOR=true
VITE_ENABLE_SOP_MANAGER=true
VITE_ENABLE_DATA_SANDBOX=true
VITE_ENABLE_KNOWLEDGE_GRAPH=true
VITE_ENABLE_REAL_TIME_MONITORING=true

# Development features
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_MOCK_DATA=false

# =============================================================================
# Banking Configuration
# =============================================================================
# Default currency for transactions
VITE_DEFAULT_CURRENCY=USD

# Maximum transaction amount for UI validation
VITE_MAX_TRANSACTION_AMOUNT=10000000

# Date formats
VITE_DATE_FORMAT=MM/dd/yyyy
VITE_DATETIME_FORMAT=MM/dd/yyyy HH:mm:ss

# =============================================================================
# UI/UX Settings
# =============================================================================
# Theme mode: 'light', 'dark', or 'auto'
VITE_DEFAULT_THEME=light

# Page size defaults
VITE_DEFAULT_PAGE_SIZE=50
VITE_MAX_PAGE_SIZE=500

# Chart refresh interval (seconds)
VITE_CHART_REFRESH_INTERVAL=30

# =============================================================================
# Performance Settings
# =============================================================================
# Enable service worker for caching
VITE_ENABLE_SERVICE_WORKER=true

# Virtual scrolling threshold
VITE_VIRTUAL_SCROLL_THRESHOLD=1000

# Debounce delay for search (milliseconds)
VITE_SEARCH_DEBOUNCE=300

# =============================================================================
# Development Settings
# =============================================================================
# Show development tools
VITE_SHOW_DEV_TOOLS=false

# API request logging
VITE_LOG_API_REQUESTS=false

# Performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# =============================================================================
# Security Settings
# =============================================================================
# Content Security Policy reporting
VITE_CSP_REPORT_URI=/api/csp-report

# Enable strict mode for React
VITE_REACT_STRICT_MODE=true