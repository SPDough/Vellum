{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vellum/contracts/security/1.0.0/schema.json",
  "title": "Security",
  "type": "object",
  "required": ["contract_type", "contract_version", "payload"],
  "properties": {
    "contract_type": { "const": "Security" },
    "contract_version": { "const": "1.0.0" },
    "source_system": { "type": "string" },
    "source_type": { "type": "string" },
    "source_record_id": { "type": "string" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "effective_at": { "type": "string", "format": "date-time" },
    "lineage": { "type": "object", "additionalProperties": true },
    "payload": {
      "type": "object",
      "required": ["security_id", "instrument_id", "name", "asset_class", "currency"],
      "properties": {
        "security_id": { "type": "string" },
        "instrument_id": { "type": "string" },
        "name": { "type": "string" },
        "isin": { "type": "string" },
        "cusip": { "type": "string" },
        "ticker": { "type": "string" },
        "asset_class": { "type": "string" },
        "currency": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
