{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vellum/contracts/exception/1.0.0/schema.json",
  "title": "Exception",
  "type": "object",
  "required": ["contract_type", "contract_version", "payload"],
  "properties": {
    "contract_type": { "const": "Exception" },
    "contract_version": { "const": "1.0.0" },
    "source_system": { "type": "string" },
    "source_type": { "type": "string" },
    "source_record_id": { "type": "string" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "effective_at": { "type": "string", "format": "date-time" },
    "lineage": { "type": "object", "additionalProperties": true },
    "payload": {
      "type": "object",
      "required": ["exception_id", "exception_type", "severity", "priority", "status", "opened_at", "summary"],
      "properties": {
        "exception_id": { "type": "string" },
        "exception_type": { "type": "string" },
        "entity_id": { "type": "string" },
        "account_id": { "type": "string" },
        "source_contract_type": { "type": "string" },
        "source_contract_id": { "type": "string" },
        "severity": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "opened_at": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "data_quality_flags": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
