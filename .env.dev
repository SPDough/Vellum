# Development Environment Configuration
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-not-for-production
DEBUG=true
LOG_LEVEL=debug

# Database Configuration
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://otomeshon:password@localhost:5432/otomeshon

# Redis Configuration
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Neo4j Configuration
NEO4J_PASSWORD=password
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# AI API Keys (Add your development keys)
OPENAI_API_KEY=sk-your-openai-dev-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-dev-key

# Development URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# CORS for development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Monitoring (Optional in dev)
GRAFANA_PASSWORD=admin

# Data Sandbox Settings
DATA_SANDBOX_MAX_RECORDS=10000
DATA_SANDBOX_EXPORT_TIMEOUT=60
WEBSOCKET_HEARTBEAT_INTERVAL=30