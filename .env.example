# Environment Configuration Template
# Copy this to .env and fill in your values

# Application Settings
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-here-change-this-in-production
DEBUG=false
LOG_LEVEL=info

# Database Configuration
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://otomeshon:${POSTGRES_PASSWORD}@postgres:5432/otomeshon

# Redis Configuration
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://redis:6379/0

# Neo4j Configuration
NEO4J_PASSWORD=your-neo4j-password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# AI API Keys
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Monitoring
GRAFANA_PASSWORD=your-grafana-password

# Domain & SSL
DOMAIN=otomeshon.com
ADMIN_EMAIL=admin@otomeshon.com

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Temporal Configuration
TEMPORAL_GRPC_ENDPOINT=temporal:7233

# Data Sandbox Settings
DATA_SANDBOX_MAX_RECORDS=100000
DATA_SANDBOX_EXPORT_TIMEOUT=300
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Security Settings (comma-separated; include local Portal dev server when needed)
CORS_ORIGINS=https://otomeshon.com,https://www.otomeshon.com,http://localhost:8080

# Startup toggles (canonical app `app.main` — disable when Postgres/Neo4j/Kafka/Temporal are not running)
STARTUP_ENABLE_NEO4J=true
STARTUP_ENABLE_KAFKA=true
STARTUP_ENABLE_TEMPORAL=true
STARTUP_ENABLE_KG_SYNC=true
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_SALT=your-strong-password-salt-change-in-production

# Demo Authentication (for development only)
DEMO_ADMIN_PASSWORD=secure_admin_123!
DEMO_ANALYST_PASSWORD=secure_analyst_123!

# File Upload Settings
MAX_UPLOAD_SIZE=100MB
UPLOAD_PATH=/app/uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=otomeshon-backups
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key