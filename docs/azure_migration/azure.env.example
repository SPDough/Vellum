# Azure Migration Environment Variables
# Copy this file to azure.env and fill in your actual values

# =============================================================================
# AZURE CORE CONFIGURATION
# =============================================================================

# Azure Tenant and Service Principal
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# AZURE KEY VAULT
# =============================================================================

# Azure Key Vault for secrets management
AZURE_KEY_VAULT_URL=https://otomeshon-kv.vault.azure.net/
AZURE_KEY_VAULT_TENANT_ID=your-tenant-id-here
AZURE_KEY_VAULT_CLIENT_ID=your-client-id-here
AZURE_KEY_VAULT_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# AZURE STORAGE
# =============================================================================

# Azure Blob Storage for file storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=otomeshonstorage;AccountKey=your-storage-key-here;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=otomeshonstorage
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key-here

# =============================================================================
# AZURE MONITOR / APPLICATION INSIGHTS
# =============================================================================

# Azure Application Insights for monitoring
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-instrumentation-key-here;IngestionEndpoint=https://eastus-8.in.applicationinsights.azure.com/;LiveEndpoint=https://eastus.livediagnostics.monitor.azure.com/
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key-here

# =============================================================================
# AZURE CONTAINER REGISTRY
# =============================================================================

# Azure Container Registry for Docker images
ACR_LOGIN_SERVER=otomeshonacr.azurecr.io
ACR_USERNAME=otomeshonacr
ACR_PASSWORD=your-acr-password-here

# =============================================================================
# AZURE DATABASE FOR POSTGRESQL
# =============================================================================

# Azure Database for PostgreSQL
AZURE_POSTGRES_SERVER=otomeshon-postgres
AZURE_POSTGRES_DATABASE=otomeshon
AZURE_POSTGRES_USER=otomeshon
AZURE_POSTGRES_PASSWORD=your-secure-postgres-password-here

# Generated PostgreSQL connection URL (auto-generated from above)
DATABASE_URL=postgresql://otomeshon:your-secure-postgres-password-here@otomeshon-postgres.postgres.database.azure.com:5432/otomeshon?sslmode=require

# =============================================================================
# AZURE CACHE FOR REDIS
# =============================================================================

# Azure Cache for Redis
AZURE_REDIS_HOST=otomeshon-redis.redis.cache.windows.net
AZURE_REDIS_PORT=6380
AZURE_REDIS_PASSWORD=your-redis-password-here
AZURE_REDIS_SSL=true

# Generated Redis connection URL (auto-generated from above)
REDIS_URL=rediss://:your-redis-password-here@otomeshon-redis.redis.cache.windows.net:6380/0?ssl=true

# =============================================================================
# AZURE SERVICE BUS (KAFKA REPLACEMENT)
# =============================================================================

# Azure Service Bus for message queuing
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://otomeshon-sb.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-service-bus-key-here
AZURE_SERVICE_BUS_NAMESPACE=otomeshon-sb

# =============================================================================
# AZURE COSMOS DB (NEO4J REPLACEMENT)
# =============================================================================

# Azure Cosmos DB for graph database
AZURE_COSMOS_DB_ENDPOINT=https://otomeshon-cosmos.documents.azure.com:443/
AZURE_COSMOS_DB_KEY=your-cosmos-db-key-here
AZURE_COSMOS_DB_DATABASE=otomeshon

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Core Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-here-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-this-in-production

# CORS Settings for Azure domains
CORS_ORIGINS=https://otomeshon.azurewebsites.net,https://www.otomeshon.azurewebsites.net,https://otomeshon-frontend.azurecontainerapps.io

# =============================================================================
# EXTERNAL SERVICES (if not using Azure alternatives)
# =============================================================================

# Neo4j (if not using Azure Cosmos DB)
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# Kafka (if not using Azure Service Bus)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Temporal (if not using Azure Durable Functions)
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233

# =============================================================================
# AI/ML SERVICES
# =============================================================================

# OpenAI API
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama (local embeddings)
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Keycloak (if not using Azure AD B2C)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Drools Rules Engine
DROOLS_URL=http://drools:8080

# =============================================================================
# OBSERVABILITY
# =============================================================================

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=otomeshon-api

# =============================================================================
# LANGCHAIN
# =============================================================================

# LangSmith/LangFuse
LANGSMITH_API_KEY=your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=otomeshon

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# React App Configuration
REACT_APP_API_URL=https://otomeshon-backend.azurecontainerapps.io
REACT_APP_KEYCLOAK_URL=https://otomeshon-keycloak.azurewebsites.net
REACT_APP_KEYCLOAK_REALM=otomeshon
REACT_APP_KEYCLOAK_CLIENT_ID=otomeshon-client

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Azure Container Apps Configuration
CONTAINER_APPS_ENVIRONMENT=otomeshon-env
CONTAINER_APPS_RESOURCE_GROUP=otomeshon-prod-rg
CONTAINER_APPS_LOCATION=eastus

# Scaling Configuration
BACKEND_MIN_REPLICAS=2
BACKEND_MAX_REPLICAS=10
FRONTEND_MIN_REPLICAS=2
FRONTEND_MAX_REPLICAS=5

# Resource Limits
BACKEND_CPU=1.0
BACKEND_MEMORY=2Gi
FRONTEND_CPU=0.5
FRONTEND_MEMORY=1Gi
